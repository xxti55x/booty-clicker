# Normalize line endings to LF across platforms
* text=auto eol=lf

# Explicit text files
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.sql   text eol=lf

# Binary assets (no diff / no line-ending conversion)
*.zip   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.mp3   binary
*.ogg   binary
*.wav   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
